{
  "name": "backend",
  "type": "module",
  "module": "index.ts",
  "private": true,
  "scripts": {
    "dev": "cd ../../ && bun --env-file apps/backend/.env --watch apps/backend/src/index.ts",
    "start": "bun dist/index.js",
    "build": "bun build src/index.ts --outdir dist --minify --production --target bun",
    "test": "bun test src",
    "add-initial-data": "bun run src/scripts/add-initial-data.ts",
    "grant-all-permissions-in-admin-roles": "bun run src/scripts/admin-permissions.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@repo/types": "workspace:*",
    "axios": "^1.13.5",
    "hono": "^4.11.9",
    "minio": "^8.0.6",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^7.0.9",
    "dbmate": "^2.30.0"
  }
}