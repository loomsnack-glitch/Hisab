# Physical phone: use your PC's LAN IP (find it with `ipconfig` on Windows).
# Example:
# EXPO_PUBLIC_BASE_API_URL=http://192.168.1.10:8000/api
#
# Android emulator: localhost is auto-rewritten to 10.0.2.2.
# USB-connected phone alternative: run `adb reverse tcp:8000 tcp:8000` and keep localhost.
EXPO_PUBLIC_BASE_API_URL=http://localhost:8000/api
