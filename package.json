{
  "name": "boxmap",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/patch-react-native-gradle-plugin.js",
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:mobile": "bun run --cwd apps/mobile start",
    "android:mobile": "bun run --cwd apps/mobile android",
    "prebuild:mobile:android": "bun run --cwd apps/mobile prebuild:android",
    "android:native:mobile": "bun run --cwd apps/mobile android:native",
    "android:native:mobile:device": "bun run --cwd apps/mobile android:native:device",
    "android:native:mobile:emulator": "bun run --cwd apps/mobile android:native:emulator",
    "ios:mobile": "bun run --cwd apps/mobile ios",
    "web:mobile": "bun run --cwd apps/mobile web",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.2",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
